# Public URL приложения (используется в auth redirect и metadata)
NEXT_PUBLIC_SITE_URL=https://shidao.ru

# Supabase (self-hosted или cloud)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# App-session cookie secret (минимум 32 символа, высокий entropy)
APP_SESSION_SECRET=replace-with-strong-random-secret

# Глобальная инвалидизация app-session через bump версии
APP_SESSION_VERSION=1

# Optional: режим автоподтверждения email (обычно false в production)
ENABLE_EMAIL_AUTOCONFIRM=false

# SMTP/email-auth для self-hosted Supabase настраивается в окружении Supabase (GoTrue),
# а не в Next.js env этого приложения. Практический runbook:
# docs/email-auth-selfhosted-supabase.md

# Optional (dev): id scheduled_lesson для быстрого перехода в workspace преподавателя
DEV_TEACHER_WORKSPACE_SCHEDULED_LESSON_ID=
