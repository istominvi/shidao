{
  "name": "shidao",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "lint": "next lint",
    "test": "npm run test:unit",
    "test:compile": "tsc -p tsconfig.test.json",
    "test:unit": "npm run test:compile && node scripts/run-node-tests.mjs --exclude browser-smoke",
    "test:browser": "npm run test:compile && node scripts/run-node-tests.mjs --include browser-smoke",
    "test:browser:ci": "REQUIRE_BROWSER_SMOKE=1 BROWSER_SMOKE_SERVER_MODE=prod npm run test:browser",
    "test:all": "npm run test:unit && npm run test:browser",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:snapshot": "scripts/refresh-schema-snapshot.sh"
  },
  "dependencies": {
    "lucide-react": "^0.503.0",
    "next": "^15.3.1",
    "react": "19.0.0",
    "react-dom": "19.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.4",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "^15.3.1",
    "playwright": "^1.53.0",
    "prettier": "^3.6.0",
    "tailwindcss": "^4.1.4",
    "typescript": "^5"
  }
}
